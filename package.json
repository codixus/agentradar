{
  "name": "agentradar-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter='*' typecheck",
    "test": "bun test",
    "build": "bun run --filter agentradar build",
    "release": "npm publish -w agentradar",
    "release:dry": "npm publish -w agentradar --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
