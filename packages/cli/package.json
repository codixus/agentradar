{
  "name": "agentradar",
  "version": "0.2.0",
  "description": "CLI to check whether a site is visible and usable to AI agents.",
  "keywords": [
    "ai-agents",
    "llm",
    "agent-readiness",
    "mcp",
    "crawlers",
    "llms-txt",
    "robots-txt",
    "seo",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentradar": "dist/index.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codixus/agentradar.git"
  },
  "homepage": "https://github.com/codixus/agentradar#readme",
  "bugs": {
    "url": "https://github.com/codixus/agentradar/issues"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/cli.ts --target=node --outfile ./dist/index.js",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "agentradar-core": "workspace:*"
  }
}
